<%- include('partials/header') %>

<!-- HERO -->
<section class="hero" id="hero">
  <div class="hero-inner">
    <p class="hero-eyebrow fade-in">Available for opportunities &middot; Cairo, Egypt</p>
    <h1 class="hero-name fade-in">Ali<br/>Hassan</h1>
    <div class="hero-typing-wrapper fade-in">
      <span class="typing-prefix">// </span>
      <span class="typing-text" id="typingText" data-roles='<%- JSON.stringify(profile.roles) %>'></span>
      <span class="typing-cursor">_</span>
    </div>
    <p class="hero-summary fade-in"><%= profile.summary %></p>
    <div class="hero-cta fade-in">
      <a href="/projects" class="btn btn-primary">View Projects</a>
      <a href="/resume" class="btn btn-outline">Download CV ↓</a>
      <a href="/contact" class="btn btn-ghost">Contact Me</a>
    </div>
  </div>
</section>

<!-- TECH MARQUEE -->
<div class="marquee-section" aria-hidden="true">
  <div class="marquee-track">
    <% const techItems = ['Python', 'Java', 'JavaScript', 'SQL', 'C#', 'C++', 'Unity', 'Node.js', 'Scikit-learn', 'Pandas', 'MySQL', 'Git', 'Hugging Face', 'Machine Learning', 'Cryptography', 'MapReduce']; %>
    <% [...techItems, ...techItems].forEach(item => { %>
      <span class="marquee-item"><%= item %></span><span class="marquee-dot"></span>
    <% }) %>
  </div>
</div>

<!-- FEATURED PROJECTS -->
<section class="section" id="featured">
  <div class="container">
    <div class="section-header reveal">
      <p class="section-label">Selected Work</p>
      <h2 class="section-title">Featured Projects</h2>
      <p class="section-sub">A selection of what I've built — spanning ML, full-stack, security, and game development.</p>
    </div>
    <div class="projects-grid">
      <% projects.filter(p => p.featured).forEach((project, i) => { %>
      <article class="project-card reveal <%= project.link ? 'project-card--link' : '' %>"
        <% if (project.link) { %>data-link="<%= project.link %>"<% } %>
        style="--delay: <%= i * 0.08 %>s">
        <div class="card-top">
          <span class="card-category"><%= project.category %></span>
          <span class="card-num">#<%= String(project.id).padStart(2, '0') %></span>
        </div>
        <h3 class="card-title"><%= project.title %></h3>
        <p class="card-desc"><%= project.description %></p>
        <div class="card-tags">
          <% project.tags.forEach(tag => { %><span class="tag"><%= tag %></span><% }) %>
        </div>
        <% if (project.link) { %>
        <a class="card-link" href="<%= project.link %>" target="_blank" rel="noopener">View on GitHub &rarr;</a>
        <% } %>
      </article>
      <% }) %>
    </div>
    <div class="section-footer reveal">
      <a href="/projects" class="btn btn-outline">All Projects &rarr;</a>
    </div>
  </div>
</section>

<!-- QUICK ABOUT -->
<section class="section section-alt">
  <div class="container">
    <div class="about-grid">
      <div class="reveal">
        <p class="section-label">About</p>
        <h2 class="section-title" style="font-size: clamp(1.6rem, 3vw, 2.2rem); margin-bottom: 1.5rem; line-height: 1.2;">CS Student.<br/>Builder. Researcher.</h2>
        <div class="about-bio">
          <p>I'm a third-year Computer Science student at the <strong>German International University in Cairo</strong>. My work spans machine learning, cryptographic implementations, full-stack development, and game engineering.</p>
          <p>I bridge theory and practice — whether training classifiers on clinical data, implementing DES from scratch, or architecting complete database systems.</p>
        </div>
        <a href="/about" class="btn btn-outline" style="margin-top: 2rem">Learn More &rarr;</a>
      </div>
      <div class="reveal">
        <p class="section-label" style="margin-bottom: 1.5rem">Human Languages</p>
        <div class="lang-list">
          <% languages.forEach(lang => { %>
          <div class="lang-item">
            <div class="lang-meta">
              <span class="lang-name"><%= lang.name %></span>
              <span class="lang-level"><%= lang.level %></span>
            </div>
            <span class="lang-pct"><%= lang.percent %>%</span>
            <div class="lang-bar">
              <div class="lang-fill" data-width="<%= lang.percent %>"></div>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
